{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Setup Environment",
            "type": "shell",
            "windows": {
                "command": "${workspaceFolder}/setup.bat"
            },
            "osx": {
                "command": "${workspaceFolder}/setup.sh"
            },
            "linux": {
                "command": "${workspaceFolder}/setup.sh"
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "detail": "Runs the setup script to install dependencies and configure the development environment. Uses setup.bat on Windows and setup.sh on macOS/Linux."
        },
        {
            "label": "Build and Run Engine (Debug)",
            "type": "shell",
            "windows": {
                "command": "${workspaceFolder}/build_and_run.bat"
            },
            "osx": {
                "command": "make -f Makefile.macos && ./SDLGameEngine"
            },
            "linux": {
                "command": "make -f Makefile.macos && ./SDLGameEngine"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "detail": "Builds and runs the TwoDEngine in debug mode in a single step."
        },
        {
            "label": "Build and Run Engine (Release)",
            "type": "shell",
            "windows": {
                "command": "${workspaceFolder}/build_and_run.bat",
                "args": [
                    "release"
                ]
            },
            "osx": {
                "command": "make -f Makefile.macos CXXFLAGS+='-O3 -DNDEBUG' && ./SDLGameEngine"
            },
            "linux": {
                "command": "make -f Makefile.macos CXXFLAGS+='-O3 -DNDEBUG' && ./SDLGameEngine"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "detail": "Builds and runs the TwoDEngine in release mode in a single step."
        },
        {
            "label": "Pack Engine (Debug)",
            "type": "shell",
            "windows": {
                "command": "${workspaceFolder}/pack_engine.bat",
                "args": [
                    "debug"
                ]
            },
            "osx": {
                "command": "${workspaceFolder}/pack_engine_macos.sh",
                "args": [
                    "debug"
                ]
            },
            "linux": {
                "command": "${workspaceFolder}/pack_engine_macos.sh",
                "args": [
                    "debug"
                ]
            },
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "detail": "Packages the TwoDEngine as a standalone distribution in debug mode with debugging symbols. Creates a self-contained package with the executable, DLLs, and assets in a 'dist-debug' directory."
        },
        {
            "label": "Pack Engine (Release)",
            "type": "shell",
            "windows": {
                "command": "${workspaceFolder}/pack_engine.bat"
            },
            "osx": {
                "command": "${workspaceFolder}/pack_engine_macos.sh"
            },
            "linux": {
                "command": "${workspaceFolder}/pack_engine_macos.sh"
            },
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "detail": "Packages the TwoDEngine as an optimized standalone distribution for release. Creates a self-contained package with the executable, DLLs, and assets in a 'dist' directory."
        },
        {
            "label": "Build Only (macOS)",
            "type": "shell",
            "command": "make",
            "args": [
                "-f",
                "Makefile.macos"
            ],
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "detail": "Builds the SDLGameEngine without running it (macOS only)."
        },
        {
            "label": "Clean Build (macOS)",
            "type": "shell",
            "command": "make",
            "args": [
                "-f",
                "Makefile.macos",
                "clean"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "detail": "Cleans all build artifacts (macOS only)."
        },
        {
            "label": "Rebuild All (macOS)",
            "type": "shell",
            "command": "make",
            "args": [
                "-f",
                "Makefile.macos",
                "rebuild"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "detail": "Cleans and rebuilds the entire project (macOS only)."
        }
    ]
}
