{
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.rulers": [100],
    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit"
    },
    "files.encoding": "utf8",
    "files.eol": "\n",
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.exclude": {
        "**/.git": true,
        "**/.DS_Store": true,
        "**/*.o": true,
        "**/*.obj": true,
        "**/*.exe": true,
        "**/*.dll": true,
        "bin/": false,
        "dist/": true
    },
    "files.associations": {
        "*.h": "cpp",
        "*.hpp": "cpp",
        "*.cpp": "cpp",
        "*.inl": "cpp"
    },
    "C_Cpp.clang_format_style": "{ BasedOnStyle: Google, IndentWidth: 4, ColumnLimit: 100, AccessModifierOffset: -4 }",
    "C_Cpp.default.includePath": [
        "${workspaceFolder}/src",
        "${workspaceFolder}/libs",
        "${workspaceFolder}/libs/glm",
        "${workspaceFolder}/libs/imgui",
        "${workspaceFolder}/libs/lua",
        "${workspaceFolder}/lua-5.4.6/src",
        "${workspaceFolder}/SDL2-2.30.5/x86_64-w64-mingw32/include/SDL2",
        "${workspaceFolder}/SDL2_image-2.8.2/x86_64-w64-mingw32/include/SDL2",
        "${workspaceFolder}/SDL2_ttf-2.22.0/x86_64-w64-mingw32/include/SDL2",
        "${workspaceFolder}/SDL2_mixer-2.8.0/x86_64-w64-mingw32/include/SDL2"
    ],
    "C_Cpp.default.defines": [
        "DEBUG"
    ],
    "C_Cpp.default.cppStandard": "c++17",
    "C_Cpp.default.intelliSenseMode": "windows-gcc-x64",
    "C_Cpp.formatting": "clangFormat",
    "C_Cpp.enhancedColorization": "enabled",
    "C_Cpp.errorSquiggles": "enabled",
    "C_Cpp.intelliSenseEngine": "default",
    "C_Cpp.suggestSnippets": true,
    "C_Cpp.vcpkg.enabled": false,
    "cmake.configureOnOpen": false,
    "git.ignoreLimitWarning": true,
    "explorer.sortOrder": "type",
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        "*.cpp": "${capture}.h, ${capture}.hpp",
        "*.h": "${capture}.cpp",
        "*.hpp": "${capture}.cpp"
    },
    "search.exclude": {
        "**/bin": true,
        "**/dist": true,
        "**/SDL2-*": true,
        "**/lua-*": true,
        "**/*.o": true,
        "**/*.obj": true,
        "**/*.exe": true,
        "**/*.dll": true
    }
}
