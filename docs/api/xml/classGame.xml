      <memberdef kind="function" id="classGame_1a0311a22e53ddb906aa1024efdced0e2f" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void Game::Destroy</definition>
        <argsstring>()</argsstring>
        <name>Destroy</name>
        <qualifiedname>Game::Destroy</qualifiedname>
        <briefdescription>
<para>Clean up and destroy all game resources. </para>
        </briefdescription>
        <detaileddescription>
<para>Performs cleanup in the following order:<orderedlist>
<listitem><para>Destroys game-specific resources (textures, sounds, entities)</para>
</listitem><listitem><para>Cleans up ImGui context</para>
</listitem><listitem><para>Destroys SDL renderer</para>
</listitem><listitem><para>Destroys SDL window</para>
</listitem><listitem><para>Closes audio system</para>
</listitem><listitem><para>Quits SDL extensions (TTF, IMG, Mixer)</para>
</listitem><listitem><para>Quits SDL</para>
</listitem></orderedlist>
</para>
<para><simplesect kind="note"><para>Should be called before the <ref refid="classGame" kindref="compound">Game</ref> object is destroyed </para>
</simplesect>
<simplesect kind="note"><para>Safe to call multiple times (subsequent calls are no-ops) </para>
</simplesect>
<simplesect kind="warning"><para>Not calling this may cause resource leaks</para>
</simplesect>
<simplesect kind="see"><para><ref refid="classGame_1adc01a7fae5261c95f7e6b41024e6c533" kindref="member">Initialize()</ref> </para>
</simplesect>
</para>
        </detaileddescription>
