# SDL2 Test Makefile for macOS Silicon
CXX = clang++
CXXFLAGS = -std=c++17 -Wall $(shell sdl2-config --cflags)
LDFLAGS = $(shell sdl2-config --libs)

TARGET = 01_sdl_test
SRC = 01_sdl_test.cpp

all: $(TARGET)

$(TARGET): $(SRC)
	$(CXX) $(CXXFLAGS) $(SRC) -o $(TARGET) $(LDFLAGS)

run: $(TARGET)
	./$(TARGET)

clean:
	rm -f $(TARGET)

.PHONY: all run clean
